import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation

# Sample data
x_data = []
y_data = []

fig, ax = plt.subplots()
line, = ax.plot([], [], color='blue')

ax.set_xlim(0, 10)
ax.set_ylim(0, 100)
ax.set_title("Animated Line - Data Growth")

def update(frame):
    x_data.append(frame)
    y_data.append(frame * 10)  # Simple increasing pattern
    line.set_data(x_data, y_data)
    return line,

ani = FuncAnimation(fig, update, frames=10, interval=500)

plt.show()