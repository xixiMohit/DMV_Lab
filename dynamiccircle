import matplotlib.pyplot as plt
from matplotlib.animation import FuncAnimation
import random

fig, ax = plt.subplots()

# Create circle
circle = plt.Circle((5, 5), 1, color='blue')
ax.add_patch(circle)

ax.set_xlim(0, 10)
ax.set_ylim(0, 10)
ax.set_aspect('equal')
ax.set_title("Dynamic Circle Animation")

def update(frame):
    # Move circle randomly
    new_x = random.uniform(1, 9)
    new_y = random.uniform(1, 9)
    circle.center = (new_x, new_y)
    
    # Change size randomly
    circle.radius = random.uniform(0.5, 2)

ani = FuncAnimation(fig, update, interval=500)

plt.show()