import matplotlib.pyplot as plt

# Sample data
data = [12, 15, 20, 22, 22, 18, 25, 30, 28, 22, 18, 15, 12, 10]

# Create histogram
plt.hist(data, bins=5, color='skyblue', edgecolor='black')

plt.title("Static Histogram")
plt.xlabel("Value Range")
plt.ylabel("Frequency")
plt.grid(axis='y')

plt.show()